# 复制成 .env 后填写真实值。CI 部署时这些值由 GitHub Secrets 注入。

# 后端签发 JWT 用的密钥。生产请用 `openssl rand -hex 48` 生成
JWT_SECRET=please-change-me-in-production

# iOS App Bundle ID
APPLE_BUNDLE_ID=com.agentzero.me

# CI 推送上来的镜像 tag（owner/repo 全小写）
IMAGE_TAG=latest
GITHUB_REPOSITORY=agentzero/agentzero

# 对外提供 API 的域名（决定证书 SAN 与 CORS Host）
# 没有自有域名时用 sslip.io: <dash-separated-ip>.sslip.io 会自动解析到该 IP
AGENTZERO_DOMAIN=47.96.115.180.nip.io

# Let's Encrypt 注册邮箱（用于证书到期提醒）
LE_EMAIL=admin@agentzero.app

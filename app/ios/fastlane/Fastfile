default_platform(:ios)

APP_IDENTIFIER = "com.agentzero.me"

platform :ios do
  desc "构建 Release 版本并上传到 TestFlight"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true,
      duration: 1200,
      in_house: false
    )

    import_certificate(
      certificate_path: ENV["IOS_DIST_CERT_P12_PATH"],
      certificate_password: ENV["IOS_DIST_CERT_PASSWORD"] || "",
      keychain_name: ENV["MATCH_KEYCHAIN_NAME"] || "fastlane_tmp_keychain",
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"] || ""
    )

    get_provisioning_profile(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      readonly: false,
      filename: "AgentZeroAppStore.mobileprovision"
    )

    update_project_provisioning(
      xcodeproj: "Runner.xcodeproj",
      target_filter: "Runner",
      profile: "AgentZeroAppStore.mobileprovision",
      build_configuration: "Release"
    )

    update_code_signing_settings(
      path: "Runner.xcodeproj",
      use_automatic_signing: false,
      team_id: "ET423E6YP2",
      code_sign_identity: "Apple Distribution",
      bundle_identifier: APP_IDENTIFIER,
      profile_name: "com.agentzero.me AppStore",
      targets: ["Runner"],
      build_configurations: ["Release"]
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "../build/ios/ipa",
      output_name: "agentzero.ipa",
      include_bitcode: false,
      include_symbols: true,
      clean: false,
      skip_profile_detection: false,
      codesigning_identity: "Apple Distribution: Minglei Chen (ET423E6YP2)",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "ET423E6YP2",
        provisioningProfiles: {
          APP_IDENTIFIER => "com.agentzero.me AppStore"
        }
      },
      xcargs: "-allowProvisioningUpdates"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/agentzero.ipa",
      skip_waiting_for_build_processing: true,
      changelog: ENV["TESTFLIGHT_CHANGELOG"] || "AgentZero 内测版本，新增智能体商店外壳"
    )
  end

  desc "仅构建不上传，用于本地排错"
  lane :build_only do
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "../build/ios/ipa",
      output_name: "agentzero.ipa",
      skip_codesigning: true
    )
  end
end
